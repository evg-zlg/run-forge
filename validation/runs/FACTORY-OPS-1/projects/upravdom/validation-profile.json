{
  "key": "low-risk-code",
  "allowed_actions": [
    "inspect",
    "validate",
    "edit_non_main_worktree",
    "commit_non_main",
    "push_non_main",
    "create_draft_pr",
    "monitor_ci",
    "create_patch_package"
  ],
  "forbidden_actions": [
    "push_to_main",
    "force_push",
    "merge_target_pr",
    "deploy",
    "db_access",
    "production_access",
    "secret_access",
    "provider_calls",
    "runtime_network_during_validation",
    "run_migrations"
  ],
  "allowed_file_patterns": [
    "src/**",
    "tests/**",
    "docs/**",
    "*.md",
    "package.json"
  ],
  "forbidden_file_patterns": [
    "**/.env*",
    "**/secrets/**",
    "**/migrations/**",
    ".github/workflows/**"
  ],
  "publication_permission": "draft_pr",
  "validation_policy": "declared local checks with network disabled",
  "ci_policy": "monitor created draft PR; never bypass required checks",
  "stop_conditions": [
    "dirty target main",
    "source HEAD changes",
    "forbidden file",
    "validation failure",
    "authority ambiguity"
  ]
}
