 // Преобразует локальную дату (из календаря) в UTC строку YYYY-MM-DD
 export function localDateToUTC(date: Date): string {
   const utc = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()))
   return utc.toISOString().split('T')[0]
 }
 
 // Преобразует UTC строку в локальную дату для отображения DD.MM.YYYY
 export function utcToLocalDisplay(utcDate: string): string {
   const [year, month, day] = utcDate.split('-')
   return `${day}.${month}.${year}`
 }
 
