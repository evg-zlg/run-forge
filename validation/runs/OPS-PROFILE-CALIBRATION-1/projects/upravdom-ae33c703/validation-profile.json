{
  "key": "frontend-low-risk",
  "discovered": {
    "network": "disabled",
    "setup": "owner_review_if_required",
    "commands": {
      "test": [
        "npm run test"
      ],
      "build": [
        "npm run build"
      ],
      "typecheck": [],
      "lint": [
        "npm run lint"
      ]
    },
    "forbidden_command_terms": [
      "migrate",
      "deploy",
      "release",
      "production",
      "seed"
    ]
  },
  "authority": {
    "extends": "low-risk-code",
    "allowed_actions": [
      "inspect",
      "validate",
      "create_patch_package",
      "promote_patch_package_to_branch",
      "commit_to_non_main_branch",
      "push_non_main_branch",
      "create_draft_pr",
      "monitor_ci"
    ],
    "forbidden_actions": [
      "push_to_main",
      "force_push",
      "merge_target_pr",
      "deploy",
      "db_access",
      "production_access",
      "secret_access",
      "provider_calls",
      "runtime_network_during_validation",
      "run_migrations"
    ],
    "allowed_file_patterns": [
      "src/**",
      "tests/**",
      "public/**",
      "*.md",
      "package.json"
    ],
    "forbidden_file_patterns": [
      "**/.env*",
      "**/secrets/**",
      "**/migrations/**",
      ".github/workflows/**"
    ],
    "publication_permission": "draft_pr",
    "validation_policy": "frontend lint, typecheck, tests, and build with network disabled",
    "ci_policy": "monitor created draft PR",
    "stop_conditions": [
      "backend or catalog data mutation",
      "source HEAD changes",
      "visual acceptance unavailable"
    ]
  }
}
