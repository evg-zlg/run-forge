{
  "schemaVersion": 1,
  "taskType": "context-pack",
  "runId": "sample-js-context",
  "artifactNamespace": "examples",
  "input": {
    "repoPath": "../../fixtures/repos/sample-js",
    "include": [
      "src/**/*.ts",
      "tests/**/*.ts",
      "README.md"
    ],
    "exclude": [
      "node_modules/**",
      "dist/**"
    ],
    "maxBytesPerFile": 12000
  },
  "outDir": "../../artifacts/runspec",
  "safety": {
    "repoWritesAllowed": false,
    "networkAllowed": false
  }
}
