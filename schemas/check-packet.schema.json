{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runforge.local/schemas/check-packet.schema.json",
  "title": "RunForge external check packet",
  "type": "object",
  "required": ["run", "events", "metrics", "safetyReport", "packetManifest", "commandResults"],
  "properties": {
    "run": {
      "type": "object",
      "required": ["schemaVersion", "runId", "taskType", "status"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "runId": { "type": "string" },
        "taskType": { "const": "external_command_check" },
        "status": { "type": "string" }
      }
    },
    "events": { "type": "array", "minItems": 1 },
    "metrics": { "$ref": "#/$defs/runScopedObject" },
    "safetyReport": { "$ref": "#/$defs/runScopedObject" },
    "packetManifest": {
      "type": "object",
      "required": ["artifacts"],
      "properties": { "artifacts": { "type": "array", "minItems": 1 } }
    },
    "commandResults": {
      "type": "object",
      "required": ["commands"],
      "properties": { "commands": { "type": "array" } }
    }
  },
  "$defs": {
    "runScopedObject": {
      "type": "object",
      "required": ["schemaVersion", "runId"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "runId": { "type": "string" }
      }
    }
  }
}
