{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runforge.local/schemas/failure-triage-packet.schema.json",
  "title": "RunForge failure triage packet",
  "type": "object",
  "required": ["run", "events", "metrics", "safetyReport", "packetManifest", "rootCause"],
  "properties": {
    "run": {
      "type": "object",
      "required": ["schemaVersion", "runId", "taskType", "status"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "runId": { "type": "string" },
        "taskType": { "const": "external_failure_triage" },
        "status": { "type": "string" }
      }
    },
    "events": { "type": "array", "minItems": 1 },
    "metrics": { "$ref": "#/$defs/runScopedObject" },
    "safetyReport": { "$ref": "#/$defs/runScopedObject" },
    "packetManifest": {
      "type": "object",
      "required": ["artifacts"],
      "properties": { "artifacts": { "type": "array", "minItems": 1 } }
    },
    "rootCause": {
      "type": "object",
      "required": ["category"],
      "properties": { "category": { "type": "string" } }
    }
  },
  "$defs": {
    "runScopedObject": {
      "type": "object",
      "required": ["schemaVersion", "runId"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "runId": { "type": "string" }
      }
    }
  }
}
