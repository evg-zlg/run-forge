{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runforge.local/schemas/code-proposal-packet.schema.json",
  "title": "RunForge code proposal packet",
  "type": "object",
  "required": ["run", "events", "metrics", "safetyReport", "packetManifest", "proposalStatus", "verificationResults"],
  "properties": {
    "run": {
      "type": "object",
      "required": ["schemaVersion", "runId", "taskType", "status"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "runId": { "type": "string" },
        "taskType": { "const": "external_code_proposal" },
        "status": { "type": "string" }
      }
    },
    "events": { "type": "array", "minItems": 1 },
    "metrics": { "$ref": "#/$defs/runScopedObject" },
    "safetyReport": { "$ref": "#/$defs/runScopedObject" },
    "packetManifest": {
      "type": "object",
      "required": ["artifacts"],
      "properties": { "artifacts": { "type": "array", "minItems": 1 } }
    },
    "proposalStatus": {
      "type": "object",
      "required": ["outcome", "humanGate"],
      "properties": {
        "outcome": { "type": "string" },
        "humanGate": { "const": "required" }
      }
    },
    "verificationResults": {
      "type": "object",
      "required": ["verificationPassed", "commands"],
      "properties": {
        "verificationPassed": { "type": "boolean" },
        "commands": { "type": "array" }
      }
    }
  },
  "$defs": {
    "runScopedObject": {
      "type": "object",
      "required": ["schemaVersion", "runId"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "runId": { "type": "string" }
      }
    }
  }
}
