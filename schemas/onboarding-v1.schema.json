{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runforge.local/schemas/onboarding-v1.schema.json",
  "title": "RunForge onboarding v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "product", "description", "runforgeVersion", "versionInfo", "transport", "entrypoint", "installation", "recommendedWorkflow", "supportedInterfaces", "unsupportedInterfaces", "commands", "contracts", "artifactContract", "safetyDefaults", "taskSpecTemplate", "targetRepository", "projectFile", "nextAction"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "product": { "const": "RunForge" },
    "description": { "type": "string", "minLength": 1 },
    "runforgeVersion": { "type": "string", "minLength": 1 },
    "versionInfo": {
      "type": "object", "additionalProperties": false, "required": ["version", "gitSha"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "gitSha": { "type": "string", "minLength": 1 },
        "upstream": { "type": "string", "minLength": 1 },
        "behindBy": { "type": "integer", "minimum": 0 }
      }
    },
    "transport": { "const": "local-cli" },
    "entrypoint": { "const": "runforge" },
    "installation": {
      "type": "object", "additionalProperties": false, "required": ["root"],
      "properties": { "root": { "type": "string", "minLength": 1 } }
    },
    "recommendedWorkflow": { "$ref": "#/$defs/nonEmptyStrings" },
    "supportedInterfaces": { "$ref": "#/$defs/nonEmptyStrings" },
    "unsupportedInterfaces": { "$ref": "#/$defs/nonEmptyStrings" },
    "commands": {
      "type": "object", "additionalProperties": false,
      "required": ["onboarding", "doctor", "submitTask", "continueTask", "ownerDecision"],
      "properties": {
        "onboarding": { "$ref": "#/$defs/nonEmptyString" },
        "doctor": { "$ref": "#/$defs/nonEmptyString" },
        "submitTask": { "$ref": "#/$defs/nonEmptyString" },
        "continueTask": { "$ref": "#/$defs/nonEmptyString" },
        "ownerDecision": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "contracts": {
      "type": "object", "additionalProperties": false,
      "required": ["onboarding", "doctor", "taskSpec", "result", "projectFile"],
      "properties": {
        "onboarding": { "$ref": "#/$defs/nonEmptyString" },
        "doctor": { "$ref": "#/$defs/nonEmptyString" },
        "taskSpec": { "$ref": "#/$defs/nonEmptyString" },
        "result": { "$ref": "#/$defs/nonEmptyString" },
        "projectFile": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "artifactContract": {
      "type": "object", "additionalProperties": false, "required": ["schemaVersion", "primaryFiles", "resultSchema"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "primaryFiles": { "type": "array", "prefixItems": [{ "const": "summary.md" }, { "const": "results.json" }], "items": false, "minItems": 2, "maxItems": 2 },
        "resultSchema": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "safetyDefaults": {
      "type": "object", "additionalProperties": false,
      "required": ["targetMainMutation", "targetMainPush", "targetPrMerge", "deploy", "databaseAccess", "productionAccess", "secretAccess", "providerCalls", "artifactsOutsideTarget", "ownerGateRequiredForApply"],
      "properties": {
        "targetMainMutation": { "const": false }, "targetMainPush": { "const": false }, "targetPrMerge": { "const": false },
        "deploy": { "const": false }, "databaseAccess": { "const": false }, "productionAccess": { "const": false },
        "secretAccess": { "const": false }, "providerCalls": { "const": false }, "artifactsOutsideTarget": { "const": true },
        "ownerGateRequiredForApply": { "const": true }
      }
    },
    "taskSpecTemplate": {
      "type": "object", "additionalProperties": false, "required": ["schemaVersion", "taskId", "task", "target", "runtime", "validation", "authority", "git", "merge", "deploy", "ownerGate"],
      "properties": {
        "schemaVersion": { "const": 2 }, "taskId": { "$ref": "#/$defs/nonEmptyString" },
        "task": { "type": "object", "additionalProperties": false, "required": ["text", "goal", "acceptanceCriteria"], "properties": { "text": { "$ref": "#/$defs/nonEmptyString" }, "goal": { "$ref": "#/$defs/nonEmptyString" }, "acceptanceCriteria": { "$ref": "#/$defs/nonEmptyStrings" } } },
        "target": { "type": "object", "additionalProperties": false, "required": ["repository", "workingDirectory"], "properties": { "repository": { "$ref": "#/$defs/nonEmptyString" }, "workingDirectory": { "$ref": "#/$defs/nonEmptyString" } } },
        "runtime": { "type": "object", "additionalProperties": false, "required": ["preference", "dependencyPreparation", "externalNetwork"], "properties": { "preference": { "enum": ["docker", "local"] }, "dependencyPreparation": { "enum": ["required", "if-needed", "disabled", "reuse-existing"] }, "externalNetwork": { "enum": ["denied", "dependency-preparation-only"] } } },
        "validation": { "type": "object", "additionalProperties": false, "required": ["mode", "commands"], "properties": { "mode": { "const": "auto" }, "commands": { "type": "array", "maxItems": 0 } } },
        "authority": { "type": "object", "additionalProperties": false, "required": ["profile", "allowProviderCalls"], "properties": { "profile": { "const": "read-only" }, "allowProviderCalls": { "const": false } } },
        "git": { "type": "object", "additionalProperties": false, "required": ["publication"], "properties": { "publication": { "const": "none" } } },
        "merge": { "type": "object", "additionalProperties": false, "required": ["policy"], "properties": { "policy": { "const": "never" } } },
        "deploy": { "type": "object", "additionalProperties": false, "required": ["policy"], "properties": { "policy": { "const": "never" } } },
        "ownerGate": { "type": "object", "additionalProperties": false, "required": ["policy"], "properties": { "policy": { "const": "stop-and-report" } } }
      }
    },
    "targetRepository": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/projectInspection" }] },
    "projectFile": {
      "type": "object", "additionalProperties": false, "required": ["path", "exists", "writeRequested", "written"],
      "properties": { "path": { "type": ["string", "null"] }, "exists": { "type": "boolean" }, "writeRequested": { "type": "boolean" }, "written": { "type": "boolean" } }
    },
    "nextAction": {
      "type": "object", "additionalProperties": false, "required": ["command", "purpose"],
      "properties": { "command": { "$ref": "#/$defs/nonEmptyString" }, "purpose": { "$ref": "#/$defs/nonEmptyString" } }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nonEmptyStrings": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } },
    "projectInspection": {
      "type": "object", "additionalProperties": false,
      "required": ["requestedPath", "requestedWorkingDirectory", "path", "repositoryRoot", "executionRoot", "workingDirectory", "exists", "isGitRepository", "head", "branch", "detachedHead", "worktree", "defaultBranch", "packageManager", "dependencyPreparation", "validationCommands"],
      "properties": {
        "requestedPath": { "$ref": "#/$defs/nonEmptyString" }, "requestedWorkingDirectory": { "$ref": "#/$defs/nonEmptyString" }, "path": { "type": ["string", "null"] }, "repositoryRoot": { "type": ["string", "null"] }, "executionRoot": { "type": ["string", "null"] }, "workingDirectory": { "type": ["string", "null"] }, "exists": { "type": "boolean" },
        "isGitRepository": { "type": "boolean" }, "head": { "type": ["string", "null"] }, "branch": { "type": ["string", "null"] },
        "detachedHead": { "type": "boolean" }, "defaultBranch": { "type": ["string", "null"] }, "packageManager": { "type": ["string", "null"] },
        "validationCommands": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "dependencyPreparation": { "type": "object", "additionalProperties": false, "required": ["supported", "lockfile", "command"], "properties": { "supported": { "type": "boolean" }, "lockfile": { "type": ["string", "null"] }, "command": { "type": ["string", "null"] } } },
        "worktree": {
          "type": "object", "additionalProperties": false, "required": ["clean", "summary"],
          "properties": { "clean": { "type": ["boolean", "null"] }, "summary": { "type": ["string", "null"] } }
        }
      }
    }
  }
}
